# Hackathon clinical app runtime config

# ASR: LFM2.5-Audio + role-tag LoRA
LFM_AUDIO_MODEL=LiquidAI/LFM2.5-Audio-1.5B-JP
LFM_AUDIO_DEVICE=cuda:0
LFM_AUDIO_CHECKPOINT=
LFM_AUDIO_CHECKPOINT_REPO=katayose/koku-ai-asr-lora-jp
LFM_AUDIO_CHECKPOINT_FILENAME=adapter_lora_best.pt
LFM_AUDIO_SYSTEM_PROMPT=Perform ASR in japanese. Use <doctor> and <patient> speaker prefix tokens.
LFM_AUDIO_MAX_NEW_TOKENS=512
LFM_AUDIO_CHUNK_SEC=20
LFM_AUDIO_CHUNK_MODE=silence
LFM_AUDIO_SILENCE_SEARCH_BEFORE_SEC=10
LFM_AUDIO_MERGE_SHORT_TAIL_SEC=8
LFM_AUDIO_ROLE_FLIP=0

# Chart/Transcript model LoRA
LFM_CHART_LORA_REPO=katayose/koku-ai-transcript-lora

# VLM: image findings
LFM_VL_ENABLED=1
LFM_VL_MODEL=LiquidAI/LFM2.5-VL-1.6B
LFM_VL_DEVICE=cuda:0
LFM_VL_MAX_NEW_TOKENS=180

# Show VLM fallback reason in the UI only when debugging.
LFM_VL_SHOW_FALLBACK_REASON=0
